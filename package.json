{
  "name": "dexter-ts",
  "version": "2026.4.1",
  "description": "Dexter - AI agent for deep financial research.",
  "type": "module",
  "main": "src/index.tsx",
  "bin": {
    "dexter-ts": "./src/index.tsx"
  },
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun --watch run src/index.tsx",
    "gateway": "tsx src/gateway/index.ts run",
    "gateway:login": "tsx src/gateway/index.ts login",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:signals": "npx jest --runInBand src/signal-engine/__tests__/rules.test.ts src/signal-engine/__tests__/daily-scan.integration.test.ts src/signal-engine/__tests__/walk-forward.test.ts src/signal-engine/__tests__/weekly-review.test.ts src/signal-engine/__tests__/portfolio-ledger.test.ts src/signal-engine/__tests__/signal-quality.test.ts src/signal-engine/__tests__/paper-trade-log.test.ts src/signal-engine/__tests__/grounded-research.test.ts src/signal-engine/__tests__/postmortem.test.ts src/signal-engine/__tests__/calibration.test.ts src/signal-engine/__tests__/daily-operator.test.ts src/signal-engine/__tests__/backtest-trial.test.ts src/signal-engine/__tests__/blocker-analytics.test.ts src/signal-engine/__tests__/pit-availability.regression.test.ts src/signal-engine/__tests__/ohlcv-alignment.regression.test.ts src/signal-engine/__tests__/technical-macd.test.ts src/signal-engine/__tests__/fundamentals-continuous.test.ts src/signal-engine/__tests__/valuation-sector.test.ts src/signal-engine/__tests__/sentiment-provider.test.ts",
    "test:walkforward": "npx jest --runInBand src/signal-engine/__tests__/walk-forward.test.ts",
    "scan:daily": "bun run src/signal-engine/daily-scan.ts",
    "scan:daily:log": "bun run src/signal-engine/daily-scan.ts --append-csv",
    "backtest:trial": "bun run src/signal-engine/backtest-trial.cli.ts",
    "backtest:matrix": "bun run src/signal-engine/cross-ticker-harness.cli.ts",
    "backtest:parity": "bun run src/signal-engine/vectorized-parity.cli.ts",
    "validation:metrics": "bun run src/signal-engine/validation/parity-metrics.cli.ts",
    "validation:offline-policy-review": "bun run src/signal-engine/validation/offline-policy-review.cli.ts",
    "validation:preflight": "bun run src/signal-engine/validation/provider-preflight.cli.ts",
    "validation:walk-forward": "bun run src/signal-engine/validation/parity-walk-forward.cli.ts",
    "research:yahoo:fetch": "bun run src/signal-engine/research/yahoo-history.cli.ts",
    "research:yahoo:normalize": "bun run src/signal-engine/research/yahoo-history.cli.ts",
    "research:price-features": "bun run src/signal-engine/research/price-feature-labels.cli.ts",
    "research:multiticker-separation": "bun run src/signal-engine/research/multiticker-separation-analysis.cli.ts",
    "research:multiticker-evidence": "bun run src/signal-engine/research/multiticker-evidence-report.cli.ts",
    "ml:dataset": "bun run src/signal-engine/ml-dataset.cli.ts",
    "ml:sidecar": "bun run src/signal-engine/ml-sidecar.cli.ts",
    "ops:daily": "bun run src/signal-engine/daily-operator.cli.ts",
    "review:blockers": "bun run src/signal-engine/blocker-analytics.cli.ts",
    "postmortem:run": "bun run src/signal-engine/postmortem.cli.ts",
    "calibration": "bun run src/signal-engine/calibration.cli.ts",
    "review:weekly": "bun run src/signal-engine/weekly-review.cli.ts",
    "quality:signals": "bun run src/signal-engine/signal-quality.cli.ts",
    "trade:ledger": "bun run src/signal-engine/trade-ledger.cli.ts",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.25",
    "@langchain/core": "^1.1.36",
    "@langchain/exa": "^1.0.1",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.3.1",
    "@langchain/tavily": "^1.2.0",
    "@mariozechner/pi-tui": "^0.52.12",
    "@mozilla/readability": "^0.6.0",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "better-sqlite3": "^12.8.0",
    "croner": "^9.1.0",
    "diff": "^8.0.4",
    "dotenv": "^17.3.1",
    "exa-js": "^2.10.1",
    "gray-matter": "^4.0.3",
    "langsmith": "^0.4.12",
    "linkedom": "^0.18.12",
    "playwright": "^1.58.2",
    "qrcode-terminal": "^0.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/jest": "^29.5.14",
    "@types/qrcode-terminal": "^0.12.2",
    "babel-jest": "^30.3.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
